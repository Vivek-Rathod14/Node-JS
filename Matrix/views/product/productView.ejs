<%- include('../header') %>
    <div class="page-wrapper">

        <div class="page-breadcrumb">
            <div class="row">
                <div class="col-12 d-flex no-block align-items-center">
                    <div class="ml-auto text-right">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="#">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Library</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <% if (productData && productData.length> 0) { %>

                <% productData.map((e)=> { %>
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm">

                            <img src="<%= e.categoreyId && e.categoreyId.img ? '/uploads/' + e.categoreyId.img : '/images/no-img.png' %>"
                                class="card-img-top">

                            <div class="card-body text-center">
                                <h5 class="card-title">
                                    <strong>Category:</strong>
                                    <%= e.categoreyId.categorey %>
                                </h5>

                                <p class="card-text text-muted">
                                    <strong>Sub Category:</strong>
                                    <%= e.subcategoreyId.subcategorey %>
                                </p>

                                <p class="text-muted">
                                    <strong>Extra Category:</strong>
                                    <%= e.extracategoreyId.extracategorey %>
                                </p>

                                <p class="text-muted">
                                    <strong>Quantity:</strong>
                                    <%= e.quantity %>
                                </p>

                                <p class="text-muted">
                                    <strong>Price:</strong>
                                    <%= e.price %>
                                </p>

                                <p class="text-muted">
                                    <strong>Description:</strong>
                                    <%= e.description %>
                                </p>

                                <a href="/product/viewProductDelete/<%= e._id %>" class="btn btn-danger btn-sm mt-2">
                                    Delete
                                </a>
                                <a href="/product/editProduct/<%= e._id %>" class="btn btn-warning btn-sm mt-2">
                                    Edit
                                </a>
                            </div>

                        </div>
                    </div>
                    <% }) %>

                        <% } else { %>
                            <div class="col-12 text-center">
                                <h4>No Blogs Found</h4>
                            </div>
                            <% } %>
        </div>

        <%- include('../footer') %>